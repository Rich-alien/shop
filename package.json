{
  "name": "duzit",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "start:frontend": "cd frontend && ng serve --port 4201",
    "start:backend": "cd backend && npx nest start"
